// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  players   Player[]
  matches   Match[]
  heroStats HeroStats[]

  @@map("teams")
}

model Hero {
  id        String     @id @default(cuid())
  name      String     @unique
  role      String     // Core, Support, Offlane, Jungler, Roamer
  createdAt DateTime   @default(now())

  heroStats HeroStats[]
  matchHeroes MatchHero[]

  @@map("heroes")
}

model Player {
  id        String     @id @default(cuid())
  name      String
  role      String
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([teamId, name])
  @@map("players")
}

model Match {
  id        String     @id @default(cuid())
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  matchType String     // "Scrim" or "Official"
  result    String     // "Win" or "Loss"
  date      DateTime   @default(now())
  
  heroes    MatchHero[]
  bans      Ban[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("matches")
}

model MatchHero {
  id        String     @id @default(cuid())
  matchId   String
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  heroId    String
  hero      Hero       @relation(fields: [heroId], references: [id])
  
  position  String     // Position/Lane
  createdAt DateTime   @default(now())

  @@unique([matchId, heroId])
  @@map("match_heroes")
}

model Ban {
  id        String     @id @default(cuid())
  matchId   String
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  heroId    String
  heroName  String     // Store hero name for flexibility
  
  createdAt DateTime   @default(now())

  @@map("bans")
}

model HeroStats {
  id        String     @id @default(cuid())
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  heroId    String
  hero      Hero       @relation(fields: [heroId], references: [id])
  
  totalMatches  Int     @default(0)
  wins          Int     @default(0)
  losses        Int     @default(0)
  winrate       Float   @default(0.0) // Calculated percentage
  
  matchType     String  @default("Overall") // "Overall", "Scrim", etc.
  
  lastUpdated   DateTime @default(now()) @updatedAt
  createdAt     DateTime @default(now())

  @@unique([teamId, heroId, matchType])
  @@map("hero_stats")
}
